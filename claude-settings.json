{
  "model": "claude-opus-4-6",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 7,
  "env": {
    "ANTHROPIC_VERTEX_PROJECT_ID": "candid-claudecode",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "0",
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "us-east5",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Wc *",
      "Mkdir *",
      "Bash(uv *)",
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Task",
      "TodoWrite",
      "Read",
      "Grep",
      "Glob",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(ls -la *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(poetry *)",
      "Bash(python *)",
      "Bash(pre-commit *)",
      "Bash(pnpm *)",
      "Bash(git -C *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(gh pr view *)",
      "Bash(fern generate *)",
      "Bash(sed *)",
      "Bash(gh api *)",
      "Bash (npx *)",
      "Bash (gh pr *)",
      "Bash(uv run *)",
      "Bash(source *)",
      "Bash(find *)",
      "Bash(Find *)",
      "*find*",
      "Bash(find * -exec *)",
      "Bash(find * | *)",
      "Bash(find * 2>/dev/null*)",
      "Bash(find * 2>*)",
      "Bash(npx tsc *)",
      "Bash(cdc snapshots *)",
      "Bash(touch *)",
      "Bash(ls *)",
      "Bash(zellij *)",
      "Bash(git *)",
      "Bash(gt *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(cdc ssh:*)",
      "Bash(cdc rules-pod:*)",
      "Bash(k-exec:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(open-pod:*)",
      "Bash(ssh:*)",
      "Bash(git stash *)",
      "Bash(gt stash *)",
      "Bash(gh stash *)"
    ]
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "Notion@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "companyAnnouncements": [
    "Welcome to Claude Code at Candid Health. Visit https://github.com/candidhealth/claude-skills for internal skills"
  ],
  "": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🟡'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🟡'"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🟡'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🔴'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🔴'"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🔴'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🟢'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh 'clear'"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "set-agent-status.sh '🔴'"
          }
        ]
      }
    ]
  }
}
